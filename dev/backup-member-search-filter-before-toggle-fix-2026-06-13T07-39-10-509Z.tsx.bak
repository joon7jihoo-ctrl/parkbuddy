'use client';

import { useEffect, useRef, useState } from 'react';

type CheckboxInfo = {
  checkbox: HTMLInputElement;
  row: HTMLElement;
  text: string;
};

function findSearchRoot(source: HTMLElement | null) {
  return source?.closest('form') ?? document.querySelector('form');
}

function findCheckboxRows(root: Element | null): CheckboxInfo[] {
  if (!root) {
    return [];
  }

  const checkboxes = Array.from(
    root.querySelectorAll<HTMLInputElement>('input[type="checkbox"]'),
  ).filter((checkbox) => {
    const name = checkbox.getAttribute('name') ?? '';
    return name.includes('member') || name.includes('participant');
  });

  return checkboxes.map((checkbox) => {
    const row =
      checkbox.closest<HTMLElement>('[data-member-row]') ??
      checkbox.closest<HTMLElement>('label') ??
      checkbox.closest<HTMLElement>('article') ??
      checkbox.closest<HTMLElement>('li') ??
      checkbox.closest<HTMLElement>('div') ??
      checkbox.parentElement ??
      checkbox;

    return {
      checkbox,
      row,
      text: (row.textContent ?? '').toLowerCase(),
    };
  });
}

export function MemberSearchFilter() {
  const containerRef = useRef<HTMLDivElement | null>(null);
  const [keyword, setKeyword] = useState('');
  const [showSelectedOnly, setShowSelectedOnly] = useState(false);
  const [totalCount, setTotalCount] = useState(0);
  const [selectedCount, setSelectedCount] = useState(0);

  useEffect(() => {
    const root = findSearchRoot(containerRef.current);

    function applyFilter() {
      const rows = findCheckboxRows(root);
      const normalizedKeyword = keyword.trim().toLowerCase();
      let nextSelectedCount = 0;

      rows.forEach(({ checkbox, row, text }) => {
        if (checkbox.checked) {
          nextSelectedCount += 1;
        }

        const matchesKeyword =
          normalizedKeyword.length === 0 || text.includes(normalizedKeyword);
        const matchesSelected = !showSelectedOnly || checkbox.checked;

        row.style.display = matchesKeyword && matchesSelected ? '' : 'none';
      });

      setTotalCount(rows.length);
      setSelectedCount(nextSelectedCount);
    }

    applyFilter();

    root?.addEventListener('change', applyFilter);
    return () => {
      root?.removeEventListener('change', applyFilter);
    };
  }, [keyword, showSelectedOnly]);

  function clearAllSelections() {
    const root = findSearchRoot(containerRef.current);
    const rows = findCheckboxRows(root);

    rows.forEach(({ checkbox, row }) => {
      checkbox.checked = false;
      row.style.display = keyword.trim()
        ? row.textContent?.toLowerCase().includes(keyword.trim().toLowerCase())
          ? ''
          : 'none'
        : '';
    });

    setSelectedCount(0);
    root?.dispatchEvent(new Event('change', { bubbles: true }));
  }

  return (
    <section
      ref={containerRef}
      className="mb-4 rounded-3xl border border-slate-200 bg-white p-4 shadow-sm"
    >
      <div className="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <h2 className="text-base font-bold text-slate-900">회원 검색</h2>
          <p className="mt-1 text-sm text-slate-500">
            이름을 입력하면 현재 회원 목록에서 바로 필터링됩니다.
          </p>
        </div>

        <div className="text-sm font-semibold text-slate-600">
          선택 {selectedCount}명 / 전체 {totalCount}명
        </div>
      </div>

      <div className="mt-4 flex flex-col gap-3 lg:flex-row">
        <input
          type="search"
          value={keyword}
          onChange={(event) => setKeyword(event.target.value)}
          placeholder="회원 이름 검색"
          className="h-12 flex-1 rounded-2xl border border-slate-200 px-4 text-sm text-slate-900 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
        />

        <button
          type="button"
          onClick={() => setShowSelectedOnly((current) => !current)}
          className="h-12 rounded-2xl border border-slate-200 px-4 text-sm font-semibold text-slate-700"
        >
          {showSelectedOnly ? '전체 회원 보기' : '선택된 회원만 보기'}
        </button>

        <button
          type="button"
          onClick={clearAllSelections}
          className="h-12 rounded-2xl border border-red-200 px-4 text-sm font-semibold text-red-600"
        >
          전체 선택 해제
        </button>
      </div>
    </section>
  );
}
