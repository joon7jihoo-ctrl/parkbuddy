import Link from 'next/link';
import { TopBar } from '@/components/TopBar';
import { EmptyState } from '@/components/EmptyState';
import { getInitial } from '@/lib/utils';
import { requireCurrentMember } from '@/server/auth';
import { deleteMember } from '@/server/actions/members';

export default async function MembersPage() {
  const { supabase, member: me } = await requireCurrentMember();

  const { data: members, error } = await supabase
    .from('members')
    .select('id, name, phone, handicap, joined_on, role, status')
    .eq('club_id', me.club_id)
    .eq('status', 'active')
    .order('name', { ascending: true });

  if (error) throw new Error(error.message);

  return (
    <main className="space-y-5">
      <TopBar
        title="회원"
        description={`총 ${members?.length ?? 0}명`}
        action={me.role === 'admin' ? { href: '/admin/members/new', label: '등록' } : undefined}
      />

      {members?.length ? (
        <section className="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {members.map((member) => (
            <article key={member.id} className="rounded-3xl bg-white p-4 shadow-sm">
              <div className="flex items-center gap-3">
                <div className="flex size-12 items-center justify-center rounded-full bg-emerald-50 font-bold text-emerald-700">
                  {getInitial(member.name)}
                </div>
                <div className="min-w-0 flex-1">
                  <div className="flex items-center gap-2">
                    <h2 className="truncate font-bold text-slate-900">{member.name}</h2>
                    {member.role === 'admin' ? <span className="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-700">운영진</span> : null}
                  </div>
                  <p className="mt-1 text-sm text-slate-500">핸디캡 {member.handicap}</p>
                </div>
              </div>

              <div className="mt-4 grid grid-cols-2 gap-2 text-sm">
                <a
                  href={member.phone ? `tel:${member.phone}` : undefined}
                  className="rounded-2xl bg-slate-100 px-3 py-2 text-center font-semibold text-slate-700"
                  aria-disabled={!member.phone}
                >
                  전화
                </a>
                {me.role === 'admin' ? (
                  <Link href={`/admin/members/${member.id}/edit`} className="rounded-2xl bg-slate-900 px-3 py-2 text-center font-semibold text-white">
                    수정
                  </Link>
                ) : (
                  <Link href={`/members/${member.id}`} className="rounded-2xl bg-slate-900 px-3 py-2 text-center font-semibold text-white">
                    상세
                  </Link>
                )}
              </div>

              {me.role === 'admin' && member.id !== me.id ? (
                <form action={deleteMember} className="mt-2">
                  <input type="hidden" name="id" value={member.id} />
                  <button type="submit" className="w-full rounded-2xl bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-600">
                    비활성화
                  </button>
                </form>
              ) : null}
            </article>
          ))}
        </section>
      ) : (
        <EmptyState title="회원이 없습니다" description="운영진이 첫 회원을 등록하면 이곳에 표시됩니다." />
      )}
    </main>
  );
}
